{
  "name": "nyro-dev",
  "build": {
    "dockerfile": "../docker/dev/Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "workspaceFolder": "/workspace/nyro",
  "runArgs": [
    "--init"
  ],
  "forwardPorts": [
    5173,
    19530,
    19531
  ],
  "portsAttributes": {
    "5173": {
      "label": "webui dev server",
      "onAutoForward": "notify"
    },
    "19530": {
      "label": "nyro proxy"
    },
    "19531": {
      "label": "nyro admin/webui"
    }
  },
  "mounts": [
    "source=nyro-cargo-registry,target=/usr/local/cargo/registry,type=volume",
    "source=nyro-cargo-git,target=/usr/local/cargo/git,type=volume",
    "source=nyro-target,target=/workspace/nyro/target,type=volume",
    "source=nyro-pnpm-store,target=/home/vscode/.local/share/pnpm/store,type=volume"
  ],
  "postCreateCommand": "cargo fetch && cd webui && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "vadimcn.vscode-lldb",
        "ms-vscode.vscode-typescript-next",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
